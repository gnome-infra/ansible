*.* action(type="omfwd"
      queue.type="linkedlist"
      queue.filename="omfwd"
      action.resumeRetryCount="-1"
      queue.saveOnShutdown="on"
      target="{{ rsyslog_remote_target }}" port="{{ rsyslog_remote_port }}" protocol="tcp"
      Template="RSYSLOG_SyslogProtocol23Format"
{% if rsyslog_client_tls %}
      StreamDriver="gtls"
      StreamDriverMode="1"
      StreamDriverAuthMode="anon"
{% endif %}
)
