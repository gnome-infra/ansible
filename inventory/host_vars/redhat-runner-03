gitlab_runner_config:
  concurrent: 2
  check_interval: 0
  session_server:
    session_timeout: 1800
  runners:
    - name: redhat-runner-03
      output_limit: 32768
      url: https://gitlab.gnome.org
      token: "{{ gitlab_runner_gbm_token }}"
      executor: docker
      environment:
        - "FF_USE_GIT_NATIVE_CLONE=true"
      docker:
        tls_verify: false
        image: fedora:latest
        privileged: true
        disable_entrypoint_overwrite: false
        oom_kill_disable: false
        disable_cache: true
        volumes:
          - /home/podman/cache:/cache
          - casd_socket:/run/casd
        shm_size: 0
        tmpfs:
          "/tmp": "rw,nosuid,nodev,exec,mode=1777"
    - name: redhat-runner-03-webkitgtk
      url: https://gitlab.gnome.org
      id: 1101
      token: "{{ gitlab_runner_webkitgtk_token }}"
      executor: docker
      environment:
        - "FF_USE_GIT_NATIVE_CLONE=true"
      cache:
        MaxUploadedArchiveSize: 0
      docker:
        tls_verify: false
        image: quay.io/fedora/fedora:latest
        privileged: false
        cap_drop:
          - all
        security_opt:
          - seccomp:/home/podman/gitlab-runner/flatpak.seccomp.json
        disable_entrypoint_overwrite: false
        oom_kill_disable: false
        disable_cache: true
        shm_size: 0
        tmpfs:
          "/tmp": "rw,nosuid,nodev,exec,mode=1777"

gitlab_runner_buildbox_casd: true
gitlab_runner_buildbox_casd_jobs: 8

gitlab_runner_enable_pydocuum: false
